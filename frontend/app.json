{
  "expo": {
    "name": "바른견로",
    "slug": "pet-walk-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/1iconlogo.png",
    "scheme": "petwalk",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F7F4EA",
        "foregroundImage": "./assets/images/1iconlogo.png",
        "backgroundImage": "./assets/images/1iconlogo.png",
        "monochromeImage": "./assets/images/1iconlogo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.kagoter.petwalkapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/1iconlogo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F7F4EA",
          "dark": {
            "backgroundColor": "#F7F4EA"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f2e56118-0734-45e4-b4e3-22091cbea637"
      }
    }
  }
}